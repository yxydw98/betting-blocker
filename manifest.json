{
  "manifest_version": 3,
  "name": "Betting Blocker",
  "version": "1.0.0",
  "description": "Blocks betting & gambling: bookmaker sites, betting links and widgets, and HLTV's betting column. Pair with an ad blocker for ads.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "embedded",
        "enabled": true,
        "path": "rules/embedded.json"
      },
      {
        "id": "navigation",
        "enabled": true,
        "path": "rules/navigation.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["data/packs.js", "src/engine.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "data/lists.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options/options.html",
  "action": {
    "default_title": "Betting Blocker",
    "default_popup": "options/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
